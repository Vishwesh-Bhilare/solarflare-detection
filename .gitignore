cat > .gitignore <<'EOF'
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/

# IDEs
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Temporary files
tmp/
temp/

# Build artifacts
dist/
build/

# Data
data/
data/raw/
data/processed/

# Keep folder structure
!data/raw/.gitkeep
!data/processed/.gitkeep

# Figures / generated outputs
outputs/
plots/
figures/
results/

# Parquet
*.parquet

# FITS
*.fits

# ZIP datasets
*.zip

# Model checkpoints
models/
checkpoints/
*.pt
*.pth
*.ckpt

# Environment variables
.env

# Misc
*.bak
EOF
